<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asistente de Ajustes propio (sales.field.config), no res.config.settings:
         se abre como diálogo y es accesible al Gerente SFA (no requiere ser admin
         del sistema). Ver models/config.py. -->
    <record id="view_sales_field_config_form" model="ir.ui.view">
        <field name="name">sales.field.config.form</field>
        <field name="model">sales.field.config</field>
        <field name="arch" type="xml">
            <form string="Ajustes de Seguimiento Comercial">
                <sheet>
                    <group string="Listas operativas del panel">
                        <field name="sfa_inactivity_days"/>
                        <field name="sfa_week_horizon_days"/>
                        <field name="sfa_recent_interaction_days"/>
                    </group>
                    <group string="Integración con CRM">
                        <field name="sfa_hide_crm_for_users"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Guardar" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sales_field_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes de Seguimiento Comercial</field>
        <field name="res_model">sales.field.config</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sales_field_config_settings"
              name="Ajustes"
              parent="menu_sales_field_config"
              sequence="5"
              action="action_sales_field_config_settings"
              groups="sales_field_sfa.group_sales_field_manager"/>
</odoo>
