<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_sales_field_root" name="Seguimiento Comercial" sequence="10" web_icon="fa fa-line-chart,#FFFFFF,#0F766E" groups="sales_field_sfa.group_sales_field_user,sales_field_sfa.group_sales_field_manager"/>

    <menuitem id="menu_sales_field_dashboard" name="Mi Panel" parent="menu_sales_field_root" sequence="5" action="sales_field_sfa.action_sales_field_dashboard" groups="sales_field_sfa.group_sales_field_user,sales_field_sfa.group_sales_field_manager"/>

    <menuitem id="menu_sales_field_interactions" name="Interacciones" parent="menu_sales_field_root" sequence="10" action="sales_field_sfa.action_sales_interaction" groups="sales_field_sfa.group_sales_field_user,sales_field_sfa.group_sales_field_manager"/>

    <record id="action_sales_field_my_customers" model="ir.actions.act_window">
        <field name="name">Mis Clientes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('user_id', '=', uid), ('sfa_excluded', '=', False)]</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>

    <menuitem id="menu_sales_field_customers" name="Mis Clientes" parent="menu_sales_field_root" sequence="20" action="sales_field_sfa.action_sales_field_my_customers" groups="sales_field_sfa.group_sales_field_user,sales_field_sfa.group_sales_field_manager"/>

    <record id="action_sales_field_my_quotes" model="ir.actions.act_window">
        <field name="name">Mis Cotizaciones</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('user_id', '=', uid), ('state', 'in', ['draft','sent']), ('partner_id.sfa_excluded', '=', False)]</field>
    </record>

    <menuitem id="menu_sales_field_quotes" name="Mis Cotizaciones" parent="menu_sales_field_root" sequence="30" action="sales_field_sfa.action_sales_field_my_quotes" groups="sales_field_sfa.group_sales_field_user,sales_field_sfa.group_sales_field_manager"/>

    <!-- Menu contenedor para todas las vistas globales de gerencia. Agrupa lo que
         antes estaba suelto en el primer nivel (Panel Gerencial, vistas del equipo,
         clientes excluidos) para no saturar el menu raiz. Solo gerencia. -->
    <menuitem id="menu_sales_field_equipo" name="Equipo" parent="menu_sales_field_root" sequence="40" groups="sales_field_sfa.group_sales_field_manager"/>

    <menuitem id="menu_sales_field_manager_dashboard" name="Panel Gerencial" parent="menu_sales_field_equipo" sequence="10" action="sales_field_sfa.action_sales_field_dashboard_manager" groups="sales_field_sfa.group_sales_field_manager"/>

    <!-- G-01: Vistas globales del equipo (solo gerencia). Sin filtro user_id=uid:
         la record rule de manager (1=1) ya permite ver todo a nivel ORM. -->
    <record id="action_sales_field_team_interactions" model="ir.actions.act_window">
        <field name="name">Interacciones del Equipo</field>
        <field name="res_model">sales.interaction</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="search_view_id" ref="view_sales_interaction_search"/>
    </record>
    <menuitem id="menu_sales_field_team_interactions" name="Interacciones del Equipo" parent="menu_sales_field_equipo" sequence="20" action="sales_field_sfa.action_sales_field_team_interactions" groups="sales_field_sfa.group_sales_field_manager"/>

    <record id="action_sales_field_team_customers" model="ir.actions.act_window">
        <field name="name">Clientes del Equipo</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('user_id', '!=', False), ('sfa_excluded', '=', False)]</field>
    </record>
    <menuitem id="menu_sales_field_team_customers" name="Clientes del Equipo" parent="menu_sales_field_equipo" sequence="30" action="sales_field_sfa.action_sales_field_team_customers" groups="sales_field_sfa.group_sales_field_manager"/>

    <record id="action_sales_field_team_quotes" model="ir.actions.act_window">
        <field name="name">Cotizaciones del Equipo</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('state', 'in', ['draft','sent']), ('partner_id.sfa_excluded', '=', False)]</field>
    </record>
    <menuitem id="menu_sales_field_team_quotes" name="Cotizaciones del Equipo" parent="menu_sales_field_equipo" sequence="40" action="sales_field_sfa.action_sales_field_team_quotes" groups="sales_field_sfa.group_sales_field_manager"/>

    <!-- Acceso directo de gerencia a clientes excluidos. Pre-agrupado por motivo
         para revisar la cartera de exclusiones de un vistazo. -->
    <record id="action_sales_field_excluded_customers" model="ir.actions.act_window">
        <field name="name">Clientes Excluidos del Seguimiento</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('sfa_excluded', '=', True)]</field>
        <field name="context">{'search_default_group_sfa_exclusion_reason': 1}</field>
        <field name="search_view_id" ref="sales_field_sfa.view_partner_search_sales_field_sfa"/>
    </record>
    <menuitem id="menu_sales_field_excluded_customers" name="Clientes Excluidos" parent="menu_sales_field_equipo" sequence="50" action="sales_field_sfa.action_sales_field_excluded_customers" groups="sales_field_sfa.group_sales_field_manager"/>

    <!-- Submenu de Configuracion: solo gerencia. Los catalogos (Canales, Estados,
         Frecuencias, Motivos) que antes eran Selection hardcodeados ahora se
         administran desde aqui. -->
    <menuitem id="menu_sales_field_config" name="Configuración" parent="menu_sales_field_root" sequence="100" groups="sales_field_sfa.group_sales_field_manager"/>
    <menuitem id="menu_sales_field_config_channel" name="Canales" parent="menu_sales_field_config" sequence="10" action="sales_field_sfa.action_sales_field_channel" groups="sales_field_sfa.group_sales_field_manager"/>
    <menuitem id="menu_sales_field_config_visit_frequency" name="Frecuencias de Visita" parent="menu_sales_field_config" sequence="20" action="sales_field_sfa.action_sales_field_visit_frequency" groups="sales_field_sfa.group_sales_field_manager"/>
    <menuitem id="menu_sales_field_config_customer_status" name="Estados de Cliente" parent="menu_sales_field_config" sequence="30" action="sales_field_sfa.action_sales_field_customer_status" groups="sales_field_sfa.group_sales_field_manager"/>
    <menuitem id="menu_sales_field_config_exclusion_reason" name="Motivos de Exclusión" parent="menu_sales_field_config" sequence="40" action="sales_field_sfa.action_sales_field_exclusion_reason" groups="sales_field_sfa.group_sales_field_manager"/>
</odoo>
