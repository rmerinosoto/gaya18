<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Filtros SFA en el search global de Contactos. Solo gerencia los ve. Permite al
         gerente abrir el menu standard de Contactos y filtrar por estado de exclusion
         SFA o agrupar por motivo de exclusion para revisar la lista completa. -->
    <record id="view_partner_search_sales_field_sfa" model="ir.ui.view">
        <field name="name">res.partner.search.sales.field.sfa</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="sfa_excluded" string="Excluidos del Seguimiento Comercial"
                        domain="[('sfa_excluded', '=', True)]"
                        groups="sales_field_sfa.group_sales_field_manager"/>
                <filter name="sfa_active" string="Activos en Seguimiento Comercial"
                        domain="[('sfa_excluded', '=', False), ('customer_rank', '>', 0)]"
                        groups="sales_field_sfa.group_sales_field_manager"/>
                <group expand="0" string="Agrupar SFA" groups="sales_field_sfa.group_sales_field_manager">
                    <filter name="group_sfa_exclusion_reason" string="Motivo de Exclusión"
                            context="{'group_by': 'sfa_exclusion_reason'}"/>
                    <filter name="group_sfa_channel" string="Canal SFA"
                            context="{'group_by': 'sfa_channel'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_sales_field_sfa" model="ir.ui.view">
        <field name="name">res.partner.form.sales.field.sfa</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <!-- why: customer_rank invisible para poder referenciarlo desde
                     el atributo invisible del grupo siguiente. -->
                <field name="customer_rank" invisible="1"/>
                <!-- why: el grupo SFA aplica solo a partners comerciales para
                     no ensuciar proveedores, contactos internos y sucursales
                     con campos que no les corresponden. -->
                <group string="Seguimiento Comercial" invisible="customer_rank == 0">
                    <field name="user_id"/>
                    <field name="sfa_customer_status"/>
                    <field name="sfa_channel"/>
                    <field name="sfa_visit_frequency"/>
                    <!-- Exclusion del seguimiento: solo Gerencia ve y modifica.
                         Vendedores ni siquiera saben que el campo existe (groups
                         lo elimina del DOM, no solo lo deshabilita). -->
                    <field name="sfa_excluded" groups="sales_field_sfa.group_sales_field_manager"/>
                    <field name="sfa_exclusion_reason"
                           groups="sales_field_sfa.group_sales_field_manager"
                           invisible="not sfa_excluded"
                           required="sfa_excluded"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
