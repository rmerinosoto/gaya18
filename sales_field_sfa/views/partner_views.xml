<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_sales_field_sfa" model="ir.ui.view">
        <field name="name">res.partner.form.sales.field.sfa</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <!-- why: customer_rank invisible para poder referenciarlo desde
                     el atributo invisible del grupo siguiente. -->
                <field name="customer_rank" invisible="1"/>
                <!-- why: el grupo SFA aplica solo a partners comerciales para
                     no ensuciar proveedores, contactos internos y sucursales
                     con campos que no les corresponden. -->
                <group string="Seguimiento Comercial" invisible="customer_rank == 0">
                    <field name="user_id"/>
                    <field name="x_customer_status"/>
                    <field name="x_channel"/>
                    <field name="x_visit_frequency"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
