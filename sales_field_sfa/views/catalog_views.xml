<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =================== Canales =================== -->
    <record id="view_sales_field_channel_tree" model="ir.ui.view">
        <field name="name">sales.field.channel.tree</field>
        <field name="model">sales.field.channel</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_sales_field_channel_form" model="ir.ui.view">
        <field name="name">sales.field.channel.form</field>
        <field name="model">sales.field.channel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_sales_field_channel" model="ir.actions.act_window">
        <field name="name">Canales</field>
        <field name="res_model">sales.field.channel</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- =================== Frecuencias de Visita =================== -->
    <record id="view_sales_field_visit_frequency_tree" model="ir.ui.view">
