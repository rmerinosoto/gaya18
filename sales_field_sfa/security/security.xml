<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- why: los grupos viven con noupdate=0 porque su implied_ids es codigo
         (define dependencias funcionales), no datos del cliente. -->
    <data noupdate="0">
        <record id="group_sales_field_user" model="res.groups">
            <field name="name">Usuario Seguimiento Comercial</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <!-- why: SFA crea sale.order desde la interaccion, asi que el usuario
                 necesita ser vendedor. El acceso de FACTURACION (account) NO se
                 implica aqui: lo agrega el modulo puente sales_field_sfa_account
                 (cuando esta instalado) para no obligar al core a depender de
                 contabilidad. -->
            <field name="implied_ids"
                   eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="group_sales_field_manager" model="res.groups">
            <field name="name">Gerente Seguimiento Comercial</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
        </record>
    </data>

    <!-- why: las reglas viven con noupdate=1 para que el admin pueda
         ajustarlas en DB sin que las pise un -u del modulo. -->
    <data noupdate="1">
        <record id="sales_interaction_rule_user" model="ir.rule">
            <field name="name">Interacciones propias</field>
            <field name="model_id" ref="model_sales_interaction"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <record id="sales_interaction_rule_manager_all" model="ir.rule">
            <field name="name">Interacciones todas (manager)</field>
            <field name="model_id" ref="model_sales_interaction"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- why: estas dos reglas NO restringen res.partner deliberadamente.
             El filtro "vendedor solo ve sus clientes" se aplica solo a nivel
             UI via el menu "Mis Clientes" (action con domain user_id=uid).
             A nivel ORM, los vendedores SFA siguen pudiendo leer/modificar
             cualquier partner — necesario para que combos en sale.order,
             account.move y otros modulos sigan funcionando. Decision
             confirmada con Rodrigo Merino (2026-05-20). -->
        <record id="res_partner_rule_user" model="ir.rule">
            <field name="name">SFA: partners sin restriccion (filtro solo en UI)</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="res_partner_rule_manager_all" model="ir.rule">
            <field name="name">SFA: partners sin restriccion (manager)</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
