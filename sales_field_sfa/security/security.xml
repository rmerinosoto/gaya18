<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_sales_field_user" model="res.groups">
            <field name="name">Usuario Seguimiento Comercial</field>
            <field name="category_id" ref="base.module_category_sales"/>
        </record>

        <record id="group_sales_field_manager" model="res.groups">
            <field name="name">Gerente Seguimiento Comercial</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
        </record>

        <record id="sales_interaction_rule_user" model="ir.rule">
            <field name="name">Interacciones propias</field>
            <field name="model_id" ref="model_sales_interaction"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <record id="sales_interaction_rule_manager_all" model="ir.rule">
            <field name="name">Interacciones todas (manager)</field>
            <field name="model_id" ref="model_sales_interaction"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="res_partner_rule_user" model="ir.rule">
            <field name="name">Clientes asignados</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="res_partner_rule_manager_all" model="ir.rule">
            <field name="name">Clientes todos (manager)</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('sales_field_sfa.group_sales_field_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
