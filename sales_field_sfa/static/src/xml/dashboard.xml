<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="sales_field_sfa.Dashboard" owl="1">
        <div class="o_sales_field_dashboard container-fluid p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">
                    <t t-if="state.managerOnly">Panel Gerencial</t>
                    <t t-else="">Mi Panel Comercial</t>
                </h2>
                <div class="d-flex align-items-center gap-2">
                    <input type="month" class="form-control" t-att-value="state.filters.month" t-on-change="onMonthChange"/>
                    <t t-if="state.data.is_manager &amp;&amp; !state.managerOnly">
                        <select class="form-select" t-att-value="state.filters.userId" t-on-change="onUserChange">
                            <t t-foreach="state.data.user_options || []" t-as="opt" t-key="opt.id">
                                <option t-att-value="opt.id">
                                    <t t-esc="opt.name"/>
                                </option>
                            </t>
                        </select>
                    </t>
                    <button class="btn btn-outline-primary" t-on-click="loadData">Actualizar</button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="alert alert-info">Cargando panel...</div>
            </t>
            <t t-else="">
                <t t-if="!state.managerOnly">
                    <div class="row g-3 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="card h-100" data-action-key="total_interactions" t-on-click="onKpiClick">
                            <div class="card-body">
                                <small class="text-muted">Total Interacciones</small>
                                <h3><t t-esc="state.data.kpis.total_interactions || 0"/></h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="visit" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Visitas</small><h3><t t-esc="state.data.kpis.visit || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="call" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Llamadas</small><h3><t t-esc="state.data.kpis.call || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="whatsapp" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">WhatsApp</small><h3><t t-esc="state.data.kpis.whatsapp || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="followup" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Seguimientos</small><h3><t t-esc="state.data.kpis.followup || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="prospect_contacted" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Prospectos Contactados</small><h3><t t-esc="state.data.kpis.prospect_contacted || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="customer_contacted" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Clientes Contactados</small><h3><t t-esc="state.data.kpis.customer_contacted || 0"/></h3></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100" data-action-key="quotations_month" t-on-click="onKpiClick"><div class="card-body"><small class="text-muted">Cotizaciones del Mes</small><h3><t t-esc="state.data.kpis.quotations_month || 0"/></h3></div></div></div>
                    <div class="col-12 col-md-6">
                        <div class="card h-100 border-success" data-action-key="paid_invoices_month_amount" t-on-click="onKpiClick">
                            <div class="card-body">
                                <small class="text-muted">Facturado Pagado del Mes</small>
                                <h3 class="text-success"><t t-esc="formatMoney(state.data.kpis.paid_invoices_month_amount)"/></h3>
                            </div>
                        </div>
                    </div>
                </div>
                </t>

                <t t-if="state.managerOnly &amp;&amp; state.data.manager &amp;&amp; state.data.manager.enabled">
                    <div class="card mb-3">
                        <div class="card-header">
                            <strong>Panel Gerencial por Vendedor</strong>
                        </div>
                        <div class="card-body">
                            <div class="row g-3 mb-3">
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Vendedores</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_sellers || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Activos</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_active_sellers || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Interacciones</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_interactions || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Cotizaciones</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_quotations || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Facturado Pagado Equipo</small>
                                        <h4 class="mb-0 text-success"><t t-esc="formatMoney(state.data.manager.kpis.team_paid_amount)"/></h4>
                                    </div>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Vendedor</th>
                                            <th class="text-end">Interacciones</th>
                                            <th class="text-end">Cotizaciones</th>
                                            <th class="text-end">Facturado Pagado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.manager.sellers_summary || []" t-as="row" t-key="row.seller_id">
                                            <tr>
                                                <td><t t-esc="row.seller_name"/></td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link p-0" t-att-data-action-key="row.interaction_action_key" t-on-click="onActionClick">
                                                        <t t-esc="row.interactions"/>
                                                    </button>
                                                </td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link p-0" t-att-data-action-key="row.quotation_action_key" t-on-click="onActionClick">
                                                        <t t-esc="row.quotations"/>
                                                    </button>
                                                </td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link p-0 text-success" t-att-data-action-key="row.paid_action_key" t-on-click="onActionClick">
                                                        <t t-esc="formatMoney(row.paid_amount)"/>
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="!(state.data.manager.sellers_summary || []).length">
                                            <tr>
                                                <td colspan="4" class="text-muted">No hay vendedores para mostrar.</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-if="state.managerOnly &amp;&amp; !(state.data.manager &amp;&amp; state.data.manager.enabled)">
                    <div class="alert alert-warning">
                        Este panel requiere permisos de gerente de seguimiento comercial.
                    </div>
                </t>

                <t t-if="!state.managerOnly">
                    <div class="row g-3">
                    <div class="col-12 col-lg-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between">
                                <span>Interacciones de hoy</span>
                                <button class="btn btn-sm btn-link" data-action-key="interactions_today" t-on-click="onActionClick">Ver todas</button>
                            </div>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="state.data.lists.interactions_today || []" t-as="item" t-key="item.id">
                                    <li class="list-group-item" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                        <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                        <small class="text-muted"><t t-esc="item.interaction_type"/> - <t t-esc="item.result"/></small>
                                    </li>
                                </t>
                                <t t-if="!(state.data.lists.interactions_today || []).length">
                                    <li class="list-group-item text-muted">Sin registros hoy.</li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between">
                                <span>Interacciones atrasadas</span>
                                <button class="btn btn-sm btn-link" data-action-key="overdue" t-on-click="onActionClick">Ver todas</button>
                            </div>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="state.data.lists.overdue || []" t-as="item" t-key="item.id">
                                    <li class="list-group-item" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                        <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                        <small class="text-danger">Próxima acción: <t t-esc="item.next_action_date"/></small>
                                    </li>
                                </t>
                                <t t-if="!(state.data.lists.overdue || []).length">
                                    <li class="list-group-item text-muted">Sin atrasadas.</li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between">
                                <span>Clientes sin interacción 30 días</span>
                                <button class="btn btn-sm btn-link" data-action-key="inactive_partners" t-on-click="onActionClick">Ver todos</button>
                            </div>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="state.data.lists.inactive_partners || []" t-as="item" t-key="item.id">
                                    <li class="list-group-item" t-att-data-record-id="item.id" t-on-click="onPartnerClick">
                                        <div class="fw-bold"><t t-esc="item.name"/></div>
                                        <small class="text-muted">Última interacción: <t t-esc="item.last_interaction || 'Sin interacciones'"/></small>
                                    </li>
                                </t>
                                <t t-if="!(state.data.lists.inactive_partners || []).length">
                                    <li class="list-group-item text-muted">Sin clientes en riesgo.</li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </div>
                </t>
            </t>
        </div>
    </t>
</templates>
