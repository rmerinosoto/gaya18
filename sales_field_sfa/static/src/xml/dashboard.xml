<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="sales_field_sfa.Dashboard" owl="1">
        <!-- o_content: clase estandar de Odoo para client actions; habilita el scroll
             vertical cuando el contenido excede el viewport. h-100 + overflow-auto son
             refuerzo defensivo para asegurar comportamiento consistente en celular. -->
        <div class="o_sales_field_dashboard o_content h-100" style="overflow-y: auto;">
        <div class="container-fluid p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">
                    <t t-if="state.managerOnly">Panel Gerencial</t>
                    <t t-else="">Mi Panel Comercial</t>
                </h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <!-- Toggle Mes/Año: solo en el Panel Gerencial (managerOnly=true).
                         El vendedor sigue viendo solo el select de mes para no confundirlo. -->
                    <t t-if="state.managerOnly">
                        <select class="form-select" t-att-value="state.filters.period" t-on-change="onPeriodChange" style="max-width: 130px;">
                            <option value="month">Por Mes</option>
                            <option value="year">Por Año</option>
                        </select>
                    </t>
                    <!-- Select de mes (visible cuando period=month, o siempre en panel del vendedor). -->
                    <t t-if="!state.managerOnly or state.filters.period === 'month'">
                        <select class="form-select" t-att-value="state.filters.month" t-on-change="onMonthChange">
                            <t t-foreach="monthOptions()" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"><t t-esc="opt.label"/></option>
                            </t>
                        </select>
                    </t>
                    <!-- Select de año (solo cuando period=year en panel gerencial). -->
                    <t t-if="state.managerOnly and state.filters.period === 'year'">
                        <select class="form-select" t-att-value="state.filters.year" t-on-change="onYearChange" style="max-width: 130px;">
                            <t t-foreach="yearOptions()" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"><t t-esc="opt.label"/></option>
                            </t>
                        </select>
                    </t>
                    <t t-if="state.data.is_manager &amp;&amp; !state.managerOnly">
                        <select class="form-select" t-att-value="state.filters.userId" t-on-change="onUserChange">
                            <t t-foreach="state.data.user_options || []" t-as="opt" t-key="opt.id">
                                <option t-att-value="opt.id">
                                    <t t-esc="opt.name"/>
                                </option>
                            </t>
                        </select>
                    </t>
                    <button class="btn btn-outline-primary" t-on-click="loadData"><i class="fa fa-refresh me-1"/>Actualizar</button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="alert alert-info"><i class="fa fa-spinner fa-pulse me-1"/>Cargando panel...</div>
            </t>
            <t t-else="">
                <t t-if="!state.managerOnly">
                    <!-- D-01: empty state contextual cuando todos los KPI son 0 -->
                    <t t-if="isMonthEmpty()">
                        <div class="card mb-3 border-info o_sfa_empty_month">
                            <div class="card-body text-center py-4">
                                <div><i class="fa fa-rocket fa-3x text-info mb-2"/></div>
                                <h4>Sin actividad este mes todavía</h4>
                                <p class="text-muted mb-3">Empieza registrando tu primer contacto del mes — visita, llamada o WhatsApp.</p>
                                <button class="btn btn-primary" t-on-click="onCreateInteraction">
                                    <i class="fa fa-plus me-1"/>Registrar nueva interacción
                                </button>
                            </div>
                        </div>
                    </t>
                    <div class="row g-2 g-md-3 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="card h-100 o_sfa_kpi" data-action-key="total_interactions" t-on-click="onKpiClick">
                            <div class="card-body p-2 p-md-3">
                                <small class="text-muted"><i class="fa fa-list me-1"/>Total Interacciones</small>
                                <h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.total_interactions || 0"/></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="visit" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-map-marker me-1"/>Visitas</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.visit || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="call" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-phone me-1"/>Llamadas</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.call || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="whatsapp" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-whatsapp me-1"/>WhatsApp</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.whatsapp || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="followup" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-repeat me-1"/>Seguimientos</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.followup || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="prospect_contacted" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-user-plus me-1"/>Prospectos Contactados</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.prospect_contacted || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="customer_contacted" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-handshake-o me-1"/>Clientes Contactados</small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.customer_contacted || 0"/></h4></div></div></div>
                    <div class="col-6 col-md-3"><div class="card h-100 o_sfa_kpi" data-action-key="quotations_month" t-on-click="onKpiClick"><div class="card-body p-2 p-md-3"><small class="text-muted"><i class="fa fa-file-text-o me-1"/>Cotizaciones <t t-esc="state.data.period_suffix || 'del Mes'"/></small><h4 class="mb-0 mt-1"><t t-esc="state.data.kpis.quotations_month || 0"/></h4></div></div></div>
                    <!-- Bloque de facturación: solo si el puente de contabilidad está instalado (has_account). -->
                    <div class="col-6 col-md-3" t-if="state.data.has_account">
                        <div class="card h-100 o_sfa_kpi border-success" data-action-key="paid_invoices_month_amount" t-on-click="onKpiClick">
                            <div class="card-body p-2 p-md-3">
                                <small class="text-muted"><i class="fa fa-money me-1"/>Facturado Pagado <t t-esc="state.data.period_suffix || 'del Mes'"/></small>
                                <h4 class="mt-1 mb-0 text-success"><t t-esc="formatMoney(state.data.kpis.paid_invoices_month_amount)"/></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" t-if="state.data.has_account">
                        <div class="card h-100 o_sfa_kpi" data-action-key="invoiced_month_amount" t-on-click="onKpiClick">
                            <div class="card-body p-2 p-md-3">
                                <small class="text-muted"><i class="fa fa-file-text me-1"/>Facturado <t t-esc="state.data.period_suffix || 'del Mes'"/></small>
                                <h4 class="mt-1 mb-0"><t t-esc="formatMoney(state.data.kpis.invoiced_month_amount)"/></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" t-if="state.data.has_account">
                        <div class="card h-100 o_sfa_kpi border-danger" data-action-key="overdue_amount" t-on-click="onKpiClick">
                            <div class="card-body p-2 p-md-3">
                                <small class="text-muted"><i class="fa fa-exclamation-circle me-1 text-danger"/>Cartera Vencida</small>
                                <h4 class="mt-1 mb-0 text-danger"><t t-esc="formatMoney(state.data.kpis.overdue_amount)"/></h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3" t-if="state.data.has_account">
                        <div class="card h-100 o_sfa_kpi">
                            <div class="card-body p-2 p-md-3">
                                <small class="text-muted"><i class="fa fa-bullseye me-1"/>Objetivo <t t-esc="state.data.period_suffix || 'del Mes'"/></small>
                                <t t-if="state.data.kpis.target_amount">
                                    <h4 class="mt-1 mb-0"><t t-esc="formatMoney(state.data.kpis.target_amount)"/></h4>
                                    <div class="progress mt-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" t-att-style="'width:' + Math.min(100, state.data.kpis.target_pct || 0) + '%'"/>
                                    </div>
                                    <small t-attf-class="text-{{ (state.data.kpis.target_pct || 0) >= 100 ? 'success' : 'muted' }}">
                                        <t t-esc="state.data.kpis.target_pct || 0"/>% cobrado del objetivo
                                    </small>
                                </t>
                                <t t-else="">
                                    <h4 class="mt-1 mb-0 text-muted">—</h4>
                                    <small class="text-muted">Sin objetivo definido</small>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                </t>

                <t t-if="state.managerOnly &amp;&amp; state.data.manager &amp;&amp; state.data.manager.enabled">
                    <div class="card mb-3">
                        <div class="card-header">
                            <strong>Panel Gerencial por Vendedor</strong>
                        </div>
                        <div class="card-body">
                            <div class="row g-3 mb-3">
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Vendedores</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_sellers || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Activos</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_active_sellers || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Interacciones</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_interactions || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-2">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Cotizaciones</small>
                                        <h4 class="mb-0"><t t-esc="state.data.manager.kpis.team_quotations || 0"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3" t-if="state.data.has_account">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Facturado Pagado Equipo</small>
                                        <h4 class="mb-0 text-success"><t t-esc="formatMoney(state.data.manager.kpis.team_paid_amount)"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3" t-if="state.data.has_account">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Facturado Equipo</small>
                                        <h4 class="mb-0"><t t-esc="formatMoney(state.data.manager.kpis.team_invoiced_amount)"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3" t-if="state.data.has_account">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Cartera Vencida Equipo</small>
                                        <h4 class="mb-0 text-danger"><t t-esc="formatMoney(state.data.manager.kpis.team_overdue_amount)"/></h4>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3" t-if="state.data.has_account">
                                    <div class="border rounded p-2 h-100">
                                        <small class="text-muted">Objetivo Equipo</small>
                                        <h4 class="mb-0"><t t-esc="formatMoney(state.data.manager.kpis.team_target_amount)"/></h4>
                                        <small t-if="state.data.manager.kpis.team_target_amount" class="text-muted">
                                            <t t-esc="state.data.manager.kpis.team_target_pct || 0"/>% cobrado
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Vendedor</th>
                                            <th class="text-end">Interacciones</th>
                                            <th class="text-end">Cotizaciones</th>
                                            <th class="text-end" t-if="state.data.has_account">Facturado Pagado</th>
                                            <th class="text-end" t-if="state.data.has_account">Facturado</th>
                                            <th class="text-end" t-if="state.data.has_account">Cartera Vencida</th>
                                            <th class="text-end" t-if="state.data.has_account">Objetivo</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.data.manager.sellers_summary || []" t-as="row" t-key="row.seller_id">
                                            <tr>
                                                <td><t t-esc="row.seller_name"/></td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link p-0" t-att-data-action-key="row.interaction_action_key" t-on-click="onActionClick">
                                                        <t t-esc="row.interactions"/>
                                                    </button>
                                                </td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link p-0" t-att-data-action-key="row.quotation_action_key" t-on-click="onActionClick">
                                                        <t t-esc="row.quotations"/>
                                                    </button>
                                                </td>
                                                <td class="text-end" t-if="state.data.has_account">
                                                    <button class="btn btn-sm btn-link p-0 text-success" t-att-data-action-key="row.paid_action_key" t-on-click="onActionClick">
                                                        <t t-esc="formatMoney(row.paid_amount)"/>
                                                    </button>
                                                </td>
                                                <td class="text-end" t-if="state.data.has_account">
                                                    <button class="btn btn-sm btn-link p-0" t-att-data-action-key="row.invoiced_action_key" t-on-click="onActionClick">
                                                        <t t-esc="formatMoney(row.invoiced_amount)"/>
                                                    </button>
                                                </td>
                                                <td class="text-end" t-if="state.data.has_account">
                                                    <button class="btn btn-sm btn-link p-0 text-danger" t-att-data-action-key="row.overdue_action_key" t-on-click="onActionClick">
                                                        <t t-esc="formatMoney(row.overdue_amount)"/>
                                                    </button>
                                                </td>
                                                <td class="text-end" t-if="state.data.has_account">
                                                    <t t-if="row.target_amount">
                                                        <t t-esc="formatMoney(row.target_amount)"/>
                                                        <span class="text-muted"> (<t t-esc="row.target_pct || 0"/>%)</span>
                                                    </t>
                                                    <t t-else=""><span class="text-muted">—</span></t>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="!(state.data.manager.sellers_summary || []).length">
                                            <tr>
                                                <td colspan="7" class="text-muted">No hay vendedores para mostrar.</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-if="state.managerOnly &amp;&amp; !(state.data.manager &amp;&amp; state.data.manager.enabled)">
                    <div class="alert alert-warning">
                        <i class="fa fa-lock me-1"/>Este panel requiere permisos de Gerente de Seguimiento Comercial.
                    </div>
                </t>

                <t t-if="!state.managerOnly">
                    <!-- S-03: bloque prioritario "Qué hacer ahora" — visible antes de la historia.
                         Solo aparece si hay algo pendiente, para no hacer ruido al inicio del mes. -->
                    <t t-if="(state.data.lists.due_today || []).length || (state.data.lists.due_this_week || []).length || (state.data.lists.overdue || []).length">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <div class="card h-100 o_sfa_list_due_today border-primary">
                                <div class="card-header d-flex justify-content-between bg-primary text-white">
                                    <span><i class="fa fa-bell me-1"/>Para hoy</span>
                                    <button class="btn btn-sm btn-link text-white" data-action-key="due_today" t-on-click="onActionClick">Ver todas</button>
                                </div>
                                <ul class="list-group list-group-flush">
                                    <t t-foreach="state.data.lists.due_today || []" t-as="item" t-key="item.id">
                                        <li class="list-group-item o_sfa_list_item border-start border-primary border-3" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                            <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                            <small class="text-muted">Última: <t t-esc="labelType(item.interaction_type)"/> · <t t-esc="labelResult(item.result)"/></small>
                                        </li>
                                    </t>
                                    <t t-if="!(state.data.lists.due_today || []).length">
                                        <li class="list-group-item text-center text-muted py-3">
                                            <small>Nada para hoy.</small>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="card h-100 o_sfa_list_due_week">
                                <div class="card-header d-flex justify-content-between">
                                    <span><i class="fa fa-calendar me-1 text-info"/>Esta semana</span>
                                    <button class="btn btn-sm btn-link" data-action-key="due_this_week" t-on-click="onActionClick">Ver todas</button>
                                </div>
                                <ul class="list-group list-group-flush">
                                    <t t-foreach="state.data.lists.due_this_week || []" t-as="item" t-key="item.id">
                                        <li class="list-group-item o_sfa_list_item border-start border-info border-3" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                            <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                            <small class="text-info"><i class="fa fa-calendar-o me-1"/>Volver el <t t-esc="item.next_action_date"/></small>
                                        </li>
                                    </t>
                                    <t t-if="!(state.data.lists.due_this_week || []).length">
                                        <li class="list-group-item text-center text-muted py-3">
                                            <small>Sin pendientes esta semana.</small>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="card h-100 o_sfa_list_overdue_priority">
                                <div class="card-header d-flex justify-content-between">
                                    <span><i class="fa fa-exclamation-triangle text-danger me-1"/>Atrasados</span>
                                    <button class="btn btn-sm btn-link" data-action-key="overdue" t-on-click="onActionClick">Ver todos</button>
                                </div>
                                <ul class="list-group list-group-flush">
                                    <t t-foreach="state.data.lists.overdue || []" t-as="item" t-key="item.id">
                                        <li class="list-group-item o_sfa_list_item border-start border-danger border-3" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                            <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                            <small class="text-danger"><i class="fa fa-clock-o me-1"/>Debiste contactar el <t t-esc="item.next_action_date"/></small>
                                        </li>
                                    </t>
                                    <t t-if="!(state.data.lists.overdue || []).length">
                                        <li class="list-group-item text-center text-muted py-3">
                                            <small>Sin atrasados.</small>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </div>
                    </div>
                    </t>
                    <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <div class="card h-100 o_sfa_list_today">
                            <div class="card-header d-flex justify-content-between">
                                <span><i class="fa fa-calendar-check-o text-success me-1"/>Interacciones registradas hoy</span>
                                <button class="btn btn-sm btn-link" data-action-key="interactions_today" t-on-click="onActionClick">Ver todas</button>
                            </div>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="state.data.lists.interactions_today || []" t-as="item" t-key="item.id">
                                    <li class="list-group-item o_sfa_list_item" t-att-data-record-id="item.id" t-on-click="onInteractionClick">
                                        <div class="fw-bold"><t t-esc="item.partner_id ? item.partner_id[1] : ''"/></div>
                                        <small class="text-muted"><t t-esc="labelType(item.interaction_type)"/> · <t t-esc="labelResult(item.result)"/></small>
                                    </li>
                                </t>
                                <t t-if="!(state.data.lists.interactions_today || []).length">
                                    <li class="list-group-item text-center text-muted py-4">
                                        <div><i class="fa fa-coffee fa-2x mb-2 text-secondary"/></div>
                                        <div class="fw-bold">Sin contactos hoy</div>
                                        <small>Cuando registres una interacción aparecerá aquí.</small>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <div class="card h-100 o_sfa_list_inactive">
                            <div class="card-header d-flex justify-content-between">
                                <span><i class="fa fa-bell-o text-warning me-1"/>Sin contacto desde hace 30 días</span>
                                <button class="btn btn-sm btn-link" data-action-key="inactive_partners" t-on-click="onActionClick">Ver todos</button>
                            </div>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="state.data.lists.inactive_partners || []" t-as="item" t-key="item.id">
                                    <li class="list-group-item o_sfa_list_item border-start border-warning border-3" t-att-data-record-id="item.id" t-on-click="onInactivePartnerClick">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold"><t t-esc="item.name"/></div>
                                                <small class="text-muted">Último contacto: <t t-esc="item.last_interaction || 'Nunca'"/></small>
                                            </div>
                                            <span class="badge bg-warning text-dark"><i class="fa fa-plus me-1"/>Contactar</span>
                                        </div>
                                    </li>
                                </t>
