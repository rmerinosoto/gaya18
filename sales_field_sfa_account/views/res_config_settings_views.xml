<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Agrega el ajuste contable al asistente de Ajustes del core. -->
    <record id="view_sales_field_config_form_account" model="ir.ui.view">
        <field name="name">sales.field.config.form.account</field>
        <field name="model">sales.field.config</field>
        <field name="inherit_id" ref="sales_field_sfa.view_sales_field_config_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Facturación (KPI Facturado Pagado)">
                    <field name="sfa_invoice_lookback_days"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
